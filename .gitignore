# Secrets and environment variables — NEVER commit these
.env
.env.*
!.env.example
.claude/settings.local.json

# macOS system files — created automatically by Finder, not your work
.DS_Store
.AppleDouble
.LSOverride

# Node.js dependencies — always re-downloadable, no need to store in Git
node_modules/

# Log files — grow forever, not part of the project
*.log
logs/

# Database files — may contain real data or get very large
*.sqlite
*.sqlite3
*.db

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo

# Build output
dist/
build/

# Python bytecode cache — regenerated automatically, not your work
__pycache__/
*.pyc

# Local health check log (generated by scripts/health-check-local.sh)
.claude/health-check.log
