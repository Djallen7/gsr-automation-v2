# GSR Automation — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# All secrets retrieved via: op item get "[item name]" --fields password --reveal

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx
# Parent page ID where all databases live (32-char, no dashes)
NOTION_PARENT_ID=367664ba431f802ab14ec19f4b77bb93

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
YOUTUBE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx
YOUTUBE_CLIENT_ID=000000000000-xxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx
# OAuth refresh token (obtain via oauth2 flow, store in 1Password)
YOUTUBE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Rumble ────────────────────────────────────────────────────────────────────
# Rumble has no public API; RSS used for status polling only
RUMBLE_CHANNEL_SLUG=godsscientificrevolution
RUMBLE_RSS_URL=https://rumble.com/feeds/godsscientificrevolution.rss

# ── Odysee / LBRY ─────────────────────────────────────────────────────────────
ODYSEE_CHANNEL_CLAIM_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ODYSEE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Dropbox ───────────────────────────────────────────────────────────────────
DROPBOX_APP_KEY=xxxxxxxxxxxxxxxx
DROPBOX_APP_SECRET=xxxxxxxxxxxxxxxx
# Long-lived refresh token (Dropbox API v2)
DROPBOX_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DROPBOX_MEDIA_ROOT=/GSR Production/

# ── Google Drive / Service Account ───────────────────────────────────────────
# Path to service account JSON key (do NOT commit the JSON file)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./config/google-service-account.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Basecamp ──────────────────────────────────────────────────────────────────
BASECAMP_ACCOUNT_ID=0000000
BASECAMP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BASECAMP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BASECAMP_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BASECAMP_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── n8n Cloud ────────────────────────────────────────────────────────────────
# Instance URL from n8n.cloud dashboard
N8N_CLOUD_WEBHOOK_BASE=https://your-instance.app.n8n.cloud/webhook/
N8N_API_KEY=n8n_api_xxxxxxxxxxxxxxxxxxxx

# ── Supabase (Hub frontend) ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ── App Config ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info
