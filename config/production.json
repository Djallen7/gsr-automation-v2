  },

  "n8n": {
    "workflows": {
      "episode_status_sync":    { "cron": "*/15 * * * *", "description": "Poll Notion for episode status changes" },
      "youtube_upload_log":     { "trigger": "webhook",   "description": "Log YouTube upload completion to Notion" },
      "graphics_reminder":      { "cron": "0 9 * * *",   "description": "Daily reminder for graphics with due dates < 48h" },
      "dropbox_asset_sync":     { "trigger": "webhook",   "description": "Sync new Dropbox files to Notion Assets" },
      "basecamp_task_sync":     { "trigger": "webhook",   "description": "Sync Basecamp todos to Notion Tasks" },
      "episode_checklist_create": { "trigger": "notion",  "description": "Auto-create task checklist on new Episode" },
      "weekly_report":          { "cron": "0 18 * * 0",  "description": "Sunday 6PM weekly pipeline report" }
    }
  },

