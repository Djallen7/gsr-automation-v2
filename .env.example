# GSR Automation v2 — Environment Variables
# Copy to .env.local (dashboard) / .env. Never commit a filled-in copy.
# Secrets are retrieved via 1Password at runtime: op item get "[item]" --fields password --reveal

# ============================================================================
# LIVE — required by the current Supabase + Next.js system
# ============================================================================

# ── Supabase (dashboard app) ────────────────────────────────────────────────
# The browser reads NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (revocable key,
# prefix sb_publishable_). The service-role key is server/edge-function only.
NEXT_PUBLIC_SUPABASE_URL=https://lafkbxypmciopebentxp.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxx   # server-side / Edge Functions only, NEVER in the browser

# ── Anthropic (server-only: /api/regenerate, /api/extract-lower-thirds, edge fn) ──
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_REGENERATE_MODEL=claude-opus-4-7

# ── Rundown Creator (in-app via /api/rc-explore + /api/rc-import) ────────────
# NOTE: RC returns errors as HTTP 200 with a JSON error body — always read the body.
RUNDOWN_CREATOR_API_KEY=xxxxxxxxxxxxxxxxxxxx
RUNDOWN_CREATOR_API_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ── Auto-extraction Edge Function (extract-on-script-save) ───────────────────
# Must match the value stored in the app_config table (key = extract_webhook_secret).
EXTRACT_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ── Dropbox (distribution trigger — future) ─────────────────────────────────
DROPBOX_APP_KEY=xxxxxxxxxxxxxxxx
DROPBOX_APP_SECRET=xxxxxxxxxxxxxxxx
DROPBOX_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DROPBOX_MEDIA_ROOT=/GSR Production/

# ── YouTube Data API v3 (distribution — future; clear the Google audit first) ─
YOUTUBE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx
YOUTUBE_CLIENT_ID=000000000000-xxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
YOUTUBE_CHANNEL_ID=UCNZS3IEQaAfwofwltbEBwuw
YOUTUBE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App config ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info

