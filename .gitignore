# Secrets and environment variables — NEVER commit these
.env
.env.*

# macOS system files — created automatically by Finder, not your work
.DS_Store
.AppleDouble
.LSOverride

# Node.js dependencies — always re-downloadable, no need to store in Git
node_modules/

# Log files — grow forever, not part of the project
*.log
logs/

# Database files — may contain real data or get very large
*.sqlite
*.sqlite3
*.db

# n8n workflow exports — review carefully before committing; may contain
# embedded credentials or webhook URLs you don't want public
workflows/n8n/*.json

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo

# Build output
dist/
build/
